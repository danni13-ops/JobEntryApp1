@page
@model JobEntryApp.Pages.BulkUploadModel
@{
    ViewData["Title"] = "Bulk Upload";
}

<div class="container-fluid px-4 mt-4">
    <h1 class="mb-3">Bulk Upload</h1>
    <p class="text-muted mb-4">
        Imports legacy <code>.xls</code> rows into Job Book (<code>dbo.Jobs</code>) and MailChart (<code>dbo.MailChart</code>).
        Tasks are created only for jobs with Mail Date today or in the future.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <form method="post" asp-page-handler="ImportLegacy" class="card p-3 shadow-sm" style="max-width: 900px;">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="SourceFilePath" class="form-label">Legacy XLS File Path</label>
            <input asp-for="SourceFilePath" class="form-control" />
            <span asp-validation-for="SourceFilePath" class="text-danger"></span>
            <small class="text-muted">Example: C:\Users\DanielleSantone\Downloads\Unconfirmed 56836.xls</small>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Import Into Job Book + MailChart</button>
            <a asp-page="/Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>

    @if (Model.LastResult is not null)
    {
        <div class="card mt-4 shadow-sm" style="max-width: 900px;">
            <div class="card-header bg-light">Last Import Summary</div>
            <div class="card-body">
                <div>Total Rows Read: <strong>@Model.LastResult.TotalRowsRead</strong></div>
                <div>Rows Skipped (invalid): <strong>@Model.LastResult.RowsSkippedInvalid</strong></div>
                <div>Rows Failed: <strong>@Model.LastResult.RowsFailed</strong></div>
                <hr />
                <div>Jobs Inserted: <strong>@Model.LastResult.JobsInserted</strong></div>
                <div>Jobs Updated: <strong>@Model.LastResult.JobsUpdated</strong></div>
                <div>MailChart Inserted: <strong>@Model.LastResult.MailInserted</strong></div>
                <div>MailChart Updated: <strong>@Model.LastResult.MailUpdated</strong></div>
                <hr />
                <div>Task Rows Created: <strong>@Model.LastResult.TaskRowsCreated</strong></div>
                <div>Jobs With Task Creation Skipped (past/no mail date): <strong>@Model.LastResult.TaskCreationSkippedJobs</strong></div>
            </div>
        </div>
    }
</div>
