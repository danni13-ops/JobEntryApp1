@page
@model JobEntryApp.Pages.Jobs.DetailsModel
@{
    ViewData["Title"] = $"Job #{Model.Job?.JobNumber}";
}

<a asp-page="/Jobs/Index">&larr; Back to Jobs</a>

@if (Model.Job is null)
{
    <p>Job not found.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center my-3">
        <div>
            <h2>Job #@Model.Job.JobNumber - @Model.Job.JobName</h2>
            <div>
                @Model.Job.Customer
                @if (!string.IsNullOrEmpty(Model.Job.SubAccount))
                {
                    @(" - " + Model.Job.SubAccount)
                }
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary">@Model.Job.Status</span>
            <a asp-page="/Tasks" asp-route-jobNumber="@Model.Job.JobNumber" class="btn btn-primary">
                View Tasks
            </a>
        </div>

    <!-- Mini Calendar for this job -->
    @await Html.PartialAsync("/Pages/Jobs/_MiniCalendar.cshtml")
    </div>

    <div class="row">
        <!-- Job Information card -->
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Job Information</span>
                    <span class="text-muted small">Read only for now</span>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-4">Mail Date</dt>
                        <dd class="col-8">@Model.Job.MailDate?.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-4">Start Date</dt>
                        <dd class="col-8">@Model.Job.StartDate?.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-4">Quantity</dt>
                        <dd class="col-8">@Model.Job.Quantity?.ToString("N0")</dd>

                        <dt class="col-4">Postage Style</dt>
                        <dd class="col-8">@Model.Job.PostageStyle</dd>

                        <dt class="col-4">Postage Class</dt>
                        <dd class="col-8">@Model.Job.PostageClass</dd>

                        <dt class="col-4">CSR</dt>
                        <dd class="col-8">@Model.Job.Csr</dd>

                        <dt class="col-4">Sales</dt>
                        <dd class="col-8">@Model.Job.Sales</dd>

                        <dt class="col-4">Data Processing</dt>
                        <dd class="col-8">@Model.Job.DataProcessing</dd>

                        <dt class="col-4">Print</dt>
                        <dd class="col-8">
                            @if (Model.Job.Print)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </dd>

                        <dt class="col-4">Two Way Match</dt>
                        <dd class="col-8">
                            @if (Model.Job.TwoWayMatch)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Job Folders placeholder -->
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">Job Folders</div>
                <div class="card-body">
                    <p class="text-muted">
                        File upload sections (Art, Control Cards, Postal, Reports, Signoffs, etc.) will go here.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Progress & Milestones -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-bar-chart-steps me-1"></i>Progress</div>
                <div class="card-body">
                    <p class="text-muted small mb-2">Job completion progress will display here once milestones are configured.</p>
                    <div class="progress" style="height: 1.25rem;" role="progressbar" aria-label="Job progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar bg-primary" style="width: 0%">0%</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-flag me-1"></i>Milestones</div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0 small text-muted">
                        <li class="mb-1"><i class="bi bi-circle me-1"></i> Data Processing</li>
                        <li class="mb-1"><i class="bi bi-circle me-1"></i> Ready for Production</li>
                        <li class="mb-1"><i class="bi bi-circle me-1"></i> In Production</li>
                        <li class="mb-1"><i class="bi bi-circle me-1"></i> Mailed</li>
                    </ul>
                    <p class="text-muted small mt-2 mb-0">Milestone tracking will update automatically as tasks complete.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Control Cards & Documents -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-card-checklist me-1"></i>Control Cards</div>
                <div class="card-body">
                    <p class="text-muted small mb-0">
                        Laser, Inkjet, and Insertion control cards will be generated and saved here once the Control Card integration is complete.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-folder2 me-1"></i>Documents</div>
                <div class="card-body">
                    <p class="text-muted small mb-0">
                        Art, postal forms, signoffs, and reports will be accessible here once folder integration is enabled.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Comments & Notes placeholder -->
    <div class="card mb-3">
        <div class="card-header fw-semibold"><i class="bi bi-chat-left-text me-1"></i>Comments &amp; Notes</div>
        <div class="card-body">
            <p class="text-muted">Comments and notes for this job will go here.</p>
        </div>
    </div>
}
