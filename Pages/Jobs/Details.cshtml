@page
@model JobEntryApp.Pages.Jobs.DetailsModel
@{
    ViewData["Title"] = $"Job #{Model.Job?.JobNumber}";
}

<a asp-page="/Jobs/Index">&larr; Back to Jobs</a>

@if (Model.Job is null)
{
    <p>Job not found.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center my-3">
        <div>
            <h2>Job #@Model.Job.JobNumber - @Model.Job.JobName</h2>
            <div>
                @Model.Job.Customer
                @if (!string.IsNullOrEmpty(Model.Job.SubAccount))
                {
                    @(" - " + Model.Job.SubAccount)
                }
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary">@Model.Job.Status</span>
            <a asp-page="/MailChart/Index" asp-route-search="@Model.Job.JobNumber" class="btn btn-outline-primary">
                View Mail Chart
            </a>
            <a asp-page="/Tasks" asp-route-jobNumber="@Model.Job.JobNumber" class="btn btn-primary">
                View Tasks
            </a>
        </div>

    <!-- Mini Calendar for this job -->
    @await Html.PartialAsync("/Pages/Jobs/_MiniCalendar.cshtml")
    </div>

    <div class="row">
        <!-- Job Information card -->
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Job Information</span>
                    <span class="text-muted small">Read only for now</span>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-4">Mail Date</dt>
                        <dd class="col-8">@Model.Job.MailDate?.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-4">Start Date</dt>
                        <dd class="col-8">@Model.Job.StartDate?.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-4">Schedule</dt>
                        <dd class="col-8">@Model.Job.JobSpeed</dd>

                        <dt class="col-4">Quantity</dt>
                        <dd class="col-8">@Model.Job.Quantity?.ToString("N0")</dd>

                        <dt class="col-4">Postage Style</dt>
                        <dd class="col-8">@Model.Job.PostageStyle</dd>

                        <dt class="col-4">Postage Class</dt>
                        <dd class="col-8">@Model.Job.PostageClass</dd>

                        <dt class="col-4">CSR</dt>
                        <dd class="col-8">@Model.Job.Csr</dd>

                        <dt class="col-4">Sales</dt>
                        <dd class="col-8">@Model.Job.Sales</dd>

                        <dt class="col-4">Data Processing</dt>
                        <dd class="col-8">@Model.Job.DataProcessing</dd>

                        <dt class="col-4">Print</dt>
                        <dd class="col-8">
                            @if (Model.Job.Print)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </dd>

                        <dt class="col-4">Two Way Match</dt>
                        <dd class="col-8">
                            @if (Model.Job.TwoWayMatch)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Job Folders placeholder -->
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">Job Folders</div>
                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.JobFolderPath))
                    {
                        <div class="mb-2">
                            <div class="small text-muted">Folder Path</div>
                            <div class="small fw-semibold">@Model.JobFolderPath</div>
                        </div>
                    }

                    <div class="mb-2">
                        @if (Model.JobFolderExists)
                        {
                            <span class="badge bg-success">Folder Created</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Folder Not Found</span>
                        }
                    </div>

                    <div class="small text-muted mb-1">Standard subfolders</div>
                    <ul class="list-unstyled small mb-0">
                        @foreach (var folder in JobEntryApp.Infrastructure.JobFolderService.StandardSubfolders)
                        {
                            <li class="mb-1">@folder</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-list-check me-1"></i>Task Summary</div>
                <div class="card-body">
                    @if (Model.TaskOverview.TotalCount == 0)
                    {
                        <p class="text-muted small mb-0">No generated tasks were found for this job yet.</p>
                    }
                    else
                    {
                        <div class="row text-center g-2 mb-3">
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Total</div>
                                    <div class="fw-semibold">@Model.TaskOverview.TotalCount</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Open</div>
                                    <div class="fw-semibold">@Model.TaskOverview.OpenCount</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Done</div>
                                    <div class="fw-semibold">@Model.TaskOverview.CompletedCount</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="small text-muted">Overdue</div>
                                    <div class="fw-semibold text-danger">@Model.TaskOverview.OverdueCount</div>
                                </div>
                            </div>
                        </div>

                        <div class="progress" style="height: 1.25rem;" role="progressbar" aria-label="Job progress" aria-valuenow="@Model.TaskOverview.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar bg-primary" style="width: @Model.TaskOverview.ProgressPercent%">@Model.TaskOverview.ProgressPercent%</div>
                        </div>

                        @if (Model.TaskOverview.StageSummaries.Any())
                        {
                            <div class="mt-3">
                                @foreach (var stage in Model.TaskOverview.StageSummaries)
                                {
                                    <div class="d-flex justify-content-between small py-1 border-bottom">
                                        <span>@stage.Stage</span>
                                        <span class="text-muted">@stage.CompletedCount / @stage.TotalCount complete</span>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-clock-history me-1"></i>Upcoming Tasks</div>
                <div class="card-body">
                    @if (!Model.TaskOverview.UpcomingTasks.Any())
                    {
                        <p class="text-muted small mb-0">No open tasks are scheduled for this job.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var task in Model.TaskOverview.UpcomingTasks)
                            {
                                var overdue = task.DueDate.HasValue && task.DueDate.Value.Date < DateTime.Today;
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <div class="fw-semibold">
                                                @if (task.TaskNumber.HasValue)
                                                {
                                                    <span class="text-muted me-1">#@task.TaskNumber</span>
                                                }
                                                @task.TaskName
                                            </div>
                                            <div class="small text-muted">@task.Stage</div>
                                        </div>
                                        <div class="text-end">
                                            @if (overdue)
                                            {
                                                <span class="badge bg-danger">Overdue</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@task.Status</span>
                                            }
                                            <div class="small text-muted mt-1">@task.DueDate?.ToString("MM/dd/yyyy")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Control Cards & Documents -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-card-checklist me-1"></i>Control Cards</div>
                <div class="card-body">
                    <p class="text-muted small mb-0">
                        Laser, Inkjet, and Insertion control cards will be generated and saved here once the Control Card integration is complete.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-folder2 me-1"></i>Documents</div>
                <div class="card-body">
                    <p class="text-muted small mb-0">
                        Art, postal forms, signoffs, and reports will be accessible here once folder integration is enabled.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Comments & Notes placeholder -->
    <div class="card mb-3">
        <div class="card-header fw-semibold"><i class="bi bi-chat-left-text me-1"></i>Comments &amp; Notes</div>
        <div class="card-body">
            <p class="text-muted">Comments and notes for this job will go here.</p>
        </div>
    </div>
}
