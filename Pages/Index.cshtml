@page
@model IndexModel
@{
    ViewData["Title"] = "Operations Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4">Operations Dashboard</h2>

    <div class="row g-3">

        <!-- JOB ENTRY -->
        <div class="col-md-3">
            <a asp-page="/NewJob" class="dashboard-card">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">Job Entry</h5>
                        <p class="card-text small">Create new job</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- JOB BOOK -->
        <div class="col-md-3">
            <a asp-page="/Jobs/Index" class="dashboard-card">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">Job Book</h5>
                        <p class="card-text small">All jobs</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- MAIL CHART -->
        <div class="col-md-3">
            <a asp-page="/MailChart/Index" class="dashboard-card">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">Mail Chart</h5>
                        <p class="card-text small">Mail schedule</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- POSTAGE -->
        <div class="col-md-3">
            <a asp-page="/Postage/Index" class="dashboard-card">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">Postage</h5>
                        <p class="card-text small">Stamp & permit reports</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- TASK SCHEDULE -->
        <div class="col-md-3">
            <a asp-page="/Tasks" class="dashboard-card">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">Task Schedule</h5>
                        <p class="card-text small">Production timeline</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- PRODUCTION -->
        <div class="col-md-3">
            <a asp-page="/TaskDashboard" class="dashboard-card">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h5 class="card-title">Production</h5>
                        <p class="card-text small">Production floor</p>
                    </div>
                </div>
            </a>
        </div>

    </div>

</div>

<style>

    .dashboard-card {
        text-decoration: none;
        color: inherit;
    }

        .dashboard-card:hover {
            transform: scale(1.03);
            transition: 0.2s;
        }

    .card {
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .card-title {
        font-weight: 600;
    }

</style>
