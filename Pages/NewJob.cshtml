@page
@model JobEntryApp.Pages.NewJobModel
@{
    ViewData["Title"] = "Job Entry Form";
}

<h1>Job Entry Form</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<form method="post" class="row g-3">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="col-md-3">
        <label asp-for="Job.JobNumber" class="form-label"></label>
        <input asp-for="Job.JobNumber" class="form-control" readonly />
    </div>
    <div class="col-md-9">
        <label asp-for="Job.JobName" class="form-label"></label>
        <input asp-for="Job.JobName" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="Job.Customer" class="form-label"></label>
        <input asp-for="Job.Customer" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Job.SubAccount" class="form-label"></label>
        <input asp-for="Job.SubAccount" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Job.Status" class="form-label"></label>
        <input asp-for="Job.Status" class="form-control" />
    </div>

    <div class="col-md-3">
        <label asp-for="Job.StartDate" class="form-label"></label>
        <input asp-for="Job.StartDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="Job.MailDate" class="form-label"></label>
        <input asp-for="Job.MailDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="Job.Quantity" class="form-label"></label>
        <input asp-for="Job.Quantity" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Job.PostageStyle" class="form-label"></label>
        <input asp-for="Job.PostageStyle" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="Job.PostageClass" class="form-label"></label>
        <input asp-for="Job.PostageClass" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Job.Csr" class="form-label"></label>
        <input asp-for="Job.Csr" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Job.DataProcessing" class="form-label"></label>
        <input asp-for="Job.DataProcessing" class="form-control" />
    </div>

    <div class="col-md-3 form-check ms-3">
        <input asp-for="Job.Print" class="form-check-input" />
        <label asp-for="Job.Print" class="form-check-label"></label>
    </div>
    <div class="col-md-3 form-check ms-3">
        <input asp-for="Job.TwoWayMatch" class="form-check-input" />
        <label asp-for="Job.TwoWayMatch" class="form-check-label"></label>
    </div>

    <div class="col-12 d-flex gap-2 mt-2">
        <button type="submit" name="action" value="createAndNew" class="btn btn-primary">Save and New</button>
        <button type="submit" name="action" value="createAndHome" class="btn btn-outline-secondary">Save and Home</button>
        <a asp-page="/Jobs/Index" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
