@page
@model JobEntryApp.Pages.TaskDashboardModel

<style>
    .task-card { border-radius:8px; border:1px solid #e9ecef; padding:12px; }
    .task-badges .badge { margin-right:6px; }
    .pagination { margin-top:12px; }
</style>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5>Tasks</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-info">@Model.StatusMessage</div>
        }

        <form method="get" class="row g-3">
            <div class="col-12">
                <input name="FilterTaskSearch" value="@Model.FilterTaskSearch" class="form-control" placeholder="Search tasks or jobs..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Stage</label>
                <select name="FilterStage" class="form-select" onchange="this.form.submit()">
                    <option value="">All Stages</option>
                    @foreach (var s in Model.Stages)
                    {
                        <option value="@s" selected="@(Model.FilterStage == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Assignee</label>
                <select name="FilterAssignee" class="form-select" onchange="this.form.submit()">
                    <option value="">All Assignees</option>
                    @foreach (var a in Model.Assignees)
                    {
                        var cnt = Model.CsrTaskCounts.ContainsKey(a) ? Model.CsrTaskCounts[a] : 0;
                        <option value="@a" selected="@(Model.FilterAssignee == a ? "selected" : null)">@a (@cnt)</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Data Processing</label>
                <select name="FilterDp" class="form-select" onchange="this.form.submit()">
                    <option value="">All DP</option>
                    @foreach (var d in Model.Dps)
                    {
                        var cnt = Model.DpJobCounts.ContainsKey(d) ? Model.DpJobCounts[d] : 0;
                        <option value="@d" selected="@(Model.FilterDp == d ? "selected" : null)">@d (@cnt)</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="FilterStatus" class="form-select" onchange="this.form.submit()">
                    <option value="all" selected="@(Model.FilterStatus == "all" ? "selected" : null)">All Status</option>
                    @foreach (var st in Model.Statuses)
                    {
                        <option value="@st" selected="@(Model.FilterStatus == st ? "selected" : null)">@st</option>
                    }
                </select>
            </div>

            <div class="col-12 d-flex justify-content-between align-items-center">
                <div>
                    <label class="form-check-label me-2">Exclude Mailed Jobs</label>
                    <input type="checkbox" name="ExcludeMailedJobs" value="true" @(Model.ExcludeMailedJobs ? "checked" : null) onchange="this.form.submit()" />
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">Apply</button>
                </div>
            </div>
        </form>

        <div class="mt-3">
            <small class="text-muted">Showing @Model.TotalCount tasks (page @Model.Page)</small>
        </div>

        <div class="mt-3">
            @if (!Model.Tasks.Any())
            {
                <p class="text-muted">No tasks found.</p>
            }
            else
            {
                <div class="row">
                    @foreach (var t in Model.Tasks)
                    {
                        <div class="col-12 mb-2">
                            <div class="task-card">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h6 class="mb-1">@t.TaskName</h6>
                                        <div class="task-badges mb-1">
                                            <span class="badge bg-light text-dark">@t.Stage</span>
                                            <span class="badge bg-light text-dark">@t.AssignedTo</span>
                                            @if (!string.IsNullOrEmpty(t.Assignee2)) { <span class="badge bg-light text-dark">@t.Assignee2</span> }
                                            <span class="small text-muted ms-2">@t.JobName</span>
                                        </div>
                                        <div class="small text-muted">Due: @t.GetDueDateDisplay()</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="mb-2">@t.Status</div>
                                        <a asp-page="/Jobs/Details" asp-route-jobNumber="@t.JobNumber" class="btn btn-sm btn-outline-primary">Open Job</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
