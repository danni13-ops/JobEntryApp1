@page
@model JobEntryApp.Pages.TaskDashboardModel
@{
    ViewData["Title"] = "Production Dashboard";
    var viewMode = Request.Query["ViewMode"].ToString();
    if (string.IsNullOrEmpty(viewMode)) { viewMode = "list"; }

    // Build a base query string that preserves existing filters for view mode switches
    var filterParams = new System.Text.StringBuilder();
    if (!string.IsNullOrEmpty(Model.FilterAssignee)) filterParams.Append($"&FilterAssignee={Uri.EscapeDataString(Model.FilterAssignee)}");
    if (!string.IsNullOrEmpty(Model.FilterDp)) filterParams.Append($"&FilterDp={Uri.EscapeDataString(Model.FilterDp)}");
    if (!string.IsNullOrEmpty(Model.FilterStage)) filterParams.Append($"&FilterStage={Uri.EscapeDataString(Model.FilterStage)}");
    if (!string.IsNullOrEmpty(Model.FilterTaskSearch)) filterParams.Append($"&FilterTaskSearch={Uri.EscapeDataString(Model.FilterTaskSearch)}");
    if (!string.IsNullOrEmpty(Model.FilterStatus)) filterParams.Append($"&FilterStatus={Uri.EscapeDataString(Model.FilterStatus)}");
    if (Model.ExcludeMailedJobs) filterParams.Append("&ExcludeMailedJobs=true");
    var filters = filterParams.ToString();
}

<style>
    .task-card { border-radius:8px; border:1px solid #e9ecef; padding:12px; }
    .task-badges .badge { margin-right:6px; }
    .pagination { margin-top:12px; }
    .section-header { font-weight:700; font-size:1rem; border-bottom:2px solid; padding-bottom:.4rem; margin-bottom:.75rem; }
    .section-header.dp { border-color:#0d6efd; color:#0d6efd; }
    .section-header.prod { border-color:#198754; color:#198754; }
    .section-header.mail { border-color:#ffc107; color:#b45309; }
    .job-summary-card { border-radius:8px; border:1px solid #e9ecef; padding:10px 12px; background:#fff; }
    .job-summary-card:hover { background:#f8f9fa; }
</style>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="section-header dp"><i class="bi bi-cpu me-1"></i>Data Processing (@Model.DataProcessingJobs.Count)</div>
        @if (!Model.DataProcessingJobs.Any())
        {
            <p class="text-muted small">No jobs in data processing.</p>
        }
        @foreach (var job in Model.DataProcessingJobs)
        {
            <div class="job-summary-card mb-2">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <a asp-page="/Jobs/Details" asp-route-jobNumber="@job.JobNumber" class="fw-semibold text-decoration-none">Job @job.JobNumber</a>
                        <div class="small">@job.JobName</div>
                        <div class="small text-muted">DP: @(job.DataProcessing ?? "–")</div>
                    </div>
                    <div class="text-end">
                        @if (job.MailDate.HasValue)
                        {
                            <div class="small text-muted">Mail: @job.MailDate.Value.ToString("MM/dd")</div>
                        }
                        @if (job.PendingTaskCount > 0)
                        {
                            <span class="badge bg-warning text-dark">@job.PendingTaskCount tasks</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="section-header prod"><i class="bi bi-check2-circle me-1"></i>Ready for Production (@Model.ReadyForProductionJobs.Count)</div>
        @if (!Model.ReadyForProductionJobs.Any())
        {
            <p class="text-muted small">No jobs ready for production.</p>
        }
        @foreach (var job in Model.ReadyForProductionJobs)
        {
            <div class="job-summary-card mb-2">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <a asp-page="/Jobs/Details" asp-route-jobNumber="@job.JobNumber" class="fw-semibold text-decoration-none">Job @job.JobNumber</a>
                        <div class="small">@job.JobName</div>
                        <div class="small text-muted">@job.Customer</div>
                    </div>
                    <div class="text-end">
                        @if (job.MailDate.HasValue)
                        {
                            <div class="small text-muted">Mail: @job.MailDate.Value.ToString("MM/dd")</div>
                        }
                        @if (job.PendingTaskCount > 0)
                        {
                            <span class="badge bg-secondary">@job.PendingTaskCount tasks</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="section-header mail"><i class="bi bi-envelope-arrow-up me-1"></i>Mailing Soon (@Model.MailingSoonJobs.Count)</div>
        @if (!Model.MailingSoonJobs.Any())
        {
            <p class="text-muted small">No jobs mailing within 7 days.</p>
        }
        @foreach (var job in Model.MailingSoonJobs)
        {
            <div class="job-summary-card mb-2">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <a asp-page="/Jobs/Details" asp-route-jobNumber="@job.JobNumber" class="fw-semibold text-decoration-none">Job @job.JobNumber</a>
                        <div class="small">@job.JobName</div>
                        <div class="small text-muted">@job.Customer</div>
                    </div>
                    <div class="text-end">
                        @if (job.MailDate.HasValue)
                        {
                            <div class="small fw-bold text-warning">Mail: @job.MailDate.Value.ToString("MM/dd")</div>
                        }
                        @if (job.PendingTaskCount > 0)
                        {
                            <span class="badge bg-danger">@job.PendingTaskCount tasks</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5>Tasks</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-info">@Model.StatusMessage</div>
        }

        <div class="btn-group mb-3" role="group">
            <a href="?ViewMode=list@(filters)" class="btn btn-sm @(viewMode == "list" ? "btn-primary" : "btn-outline-primary")">&#9776; List</a>
            <a href="?ViewMode=jobs@(filters)" class="btn btn-sm @(viewMode == "jobs" ? "btn-primary" : "btn-outline-primary")">&#128194; Jobs</a>
            <a href="?ViewMode=upcoming@(filters)" class="btn btn-sm @(viewMode == "upcoming" ? "btn-primary" : "btn-outline-primary")">&#128197; Upcoming</a>
            <a href="?ViewMode=calendar@(filters)" class="btn btn-sm @(viewMode == "calendar" ? "btn-primary" : "btn-outline-primary")">&#128197; Calendar</a>
        </div>

        <form method="get" class="row g-3">
            <input type="hidden" name="ViewMode" value="@viewMode" />
            <div class="col-12">
                <input name="FilterTaskSearch" value="@Model.FilterTaskSearch" class="form-control" placeholder="Search tasks or jobs..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Stage</label>
                <select name="FilterStage" class="form-select" onchange="this.form.submit()">
                    <option value="">All Stages</option>
                    @foreach (var s in Model.Stages)
                    {
                        <option value="@s" selected="@(Model.FilterStage == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Assignee</label>
                <select name="FilterAssignee" class="form-select" onchange="this.form.submit()">
                    <option value="">All Assignees</option>
                    @foreach (var a in Model.Assignees)
                    {
                        var cnt = Model.CsrTaskCounts.ContainsKey(a) ? Model.CsrTaskCounts[a] : 0;
                        <option value="@a" selected="@(Model.FilterAssignee == a ? "selected" : null)">@a (@cnt)</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Data Processing</label>
                <select name="FilterDp" class="form-select" onchange="this.form.submit()">
                    <option value="">All DP</option>
                    @foreach (var d in Model.Dps)
                    {
                        var cnt = Model.DpJobCounts.ContainsKey(d) ? Model.DpJobCounts[d] : 0;
                        <option value="@d" selected="@(Model.FilterDp == d ? "selected" : null)">@d (@cnt)</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="FilterStatus" class="form-select" onchange="this.form.submit()">
                    <option value="all" selected="@(Model.FilterStatus == "all" ? "selected" : null)">All Status</option>
                    @foreach (var st in Model.Statuses)
                    {
                        <option value="@st" selected="@(Model.FilterStatus == st ? "selected" : null)">@st</option>
                    }
                </select>
            </div>

            <div class="col-12 d-flex justify-content-between align-items-center">
                <div>
                    <label class="form-check-label me-2">Exclude Mailed Jobs</label>
                    <input type="checkbox" name="ExcludeMailedJobs" value="true" @(Model.ExcludeMailedJobs ? "checked" : null) onchange="this.form.submit()" />
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">Apply</button>
                </div>
            </div>
        </form>

        <div class="mt-3">
            <small class="text-muted">Showing @Model.TotalCount tasks (page @Model.Page)</small>
        </div>

        <div class="mt-3">
            @if (!Model.Tasks.Any() && viewMode != "upcoming" && viewMode != "calendar")
            {
                <p class="text-muted">No tasks found.</p>
            }
            else if (viewMode == "jobs")
            {
                foreach (var jobGroup in Model.Tasks.GroupBy(t => t.JobNumber))
                {
                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <strong>Job @jobGroup.Key</strong>
                            — @jobGroup.First().JobName
                        </div>
                        <div class="card-body">
                            @foreach (var t in jobGroup)
                            {
                                <div class="border-bottom pb-2 mb-2">
                                    <strong>@t.TaskName</strong>
                                    <span class="badge bg-light text-dark">@t.Stage</span>
                                    <span class="small text-muted ms-2">Due: @t.GetDueDateDisplay()</span>
                                    <span class="badge bg-secondary">@t.Status</span>
                                    @if (t.IsOverdue)
                                    {
                                        <span class="badge bg-danger">Overdue</span>
                                    }
                                    else if (t.IsDueToday)
                                    {
                                        <span class="badge bg-warning text-dark">Today</span>
                                    }
                                    else if (t.IsDueSoon)
                                    {
                                        <span class="badge bg-info text-dark">Soon</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else if (viewMode == "upcoming")
            {
                <h5>Upcoming Tasks</h5>
                @foreach (var t in Model.UpcomingTasks)
                {
                    <div class="task-card mb-2">
                        <strong>@t.TaskName</strong>
                        @if (t.IsOverdue)
                        {
                            <span class="badge bg-danger">Overdue</span>
                        }
                        else if (t.IsDueToday)
                        {
                            <span class="badge bg-warning text-dark">Today</span>
                        }
                        else if (t.IsDueSoon)
                        {
                            <span class="badge bg-info text-dark">Soon</span>
                        }
                        <div class="small">@t.JobName</div>
                        <div class="small text-muted">Due: @t.GetDueDateDisplay()</div>
                    </div>
                }
            }
            else if (viewMode == "calendar")
            {
                <partial name="/Pages/Jobs/_MiniCalendar.cshtml" />
            }
            else
            {
                <div class="row">
                    @foreach (var t in Model.Tasks)
                    {
                        <div class="col-12 mb-2">
                            <div class="task-card">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h6 class="mb-1">@t.TaskName</h6>
                                        <div class="task-badges mb-1">
                                            <span class="badge bg-light text-dark">@t.Stage</span>
                                            <span class="badge bg-light text-dark">@t.AssignedTo</span>
                                            @if (!string.IsNullOrEmpty(t.Assignee2)) { <span class="badge bg-light text-dark">@t.Assignee2</span> }
                                            <span class="small text-muted ms-2">@t.JobName</span>
                                        </div>
                                        <div class="small text-muted">Due: @t.GetDueDateDisplay()</div>
                                        <div class="task-badges mt-1">
                                            @if (t.IsOverdue)
                                            {
                                                <span class="badge bg-danger">Overdue</span>
                                            }
                                            else if (t.IsDueToday)
                                            {
                                                <span class="badge bg-warning text-dark">Today</span>
                                            }
                                            else if (t.IsDueSoon)
                                            {
                                                <span class="badge bg-info text-dark">Soon</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="mb-2">@t.Status</div>
                                        <a asp-page="/Jobs/Details" asp-route-jobNumber="@t.JobNumber" class="btn btn-sm btn-outline-primary">Open Job</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
